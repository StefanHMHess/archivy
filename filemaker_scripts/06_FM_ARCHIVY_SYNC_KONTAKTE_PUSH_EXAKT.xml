<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC KONTAKTE PUSH (entwurf) - uebertraegt Kontakte aus FileMaker nach Supabase (Upsert via fm_id). BVH wird aus den Kontaktdaten mitgesendet.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Case ( not IsEmpty ( $$SUPABASE_SERVICE_KEY ) ; $$SUPABASE_SERVICE_KEY ; $$SUPABASE_KEY )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( IsEmpty ( $$FM_KONTAKTE_TABELLE ) ; "Interessenten" ; $$FM_KONTAKTE_TABELLE )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$kontakte_tabelle</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL & "/rest/v1/kontakte?on_conflict=fm_id"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.SQL.Execute"; "";
"SELECT \"Interessenten_ID\", \"Vorname\", \"Nachname\", \"Typ\", \"Email\", \"Telefon\", \"Budget\", \"Interesse\", \"BVH\", \"Status\", \"Makler\", \"Notiz\" FROM \"" & $kontakte_tabelle & "\" WHERE \"IM_sync\" IN ('x','X')")
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$sql</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
If ( Left ( $sql ; 5 ) = "[MBS]" ; "[]" ;
Let([
  j = MBS("FM.SQL.JSONRecords"; $sql;
    "fm_id" & ¶ &
    "vorname" & ¶ &
    "nachname" & ¶ &
    "typ" & ¶ &
    "email" & ¶ &
    "telefon" & ¶ &
    "budget" & ¶ &
    "interesse" & ¶ &
    "bvh" & ¶ &
    "status" & ¶ &
    "makler" & ¶ &
    "notiz"
  )
];
  If ( Left ( j ; 5 ) = "[MBS]" ; "[]" ; j )
)
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$json_raw</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.SQL.Release"; $sql)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$release</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Substitute ( $json_raw ;
  [": \"\"" ; ": null"] ;
  [":\"\"" ; ":null"]
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$json</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( JSONGetElementType ( $json ; "" ) = JSONArray ; ValueCount ( JSONListKeys ( $json ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$anzahl = 0]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Msgbox"; "Archivy Sync Kontakte Push" & Char(182) & "Keine Kontakte mit IM_sync = x gefunden." & Char(182) & "Quelle: " & $kontakte_tabelle)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$msg</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$curl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $curl; $url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $curl; "apikey: " & $key; "Authorization: Bearer " & $key; "Content-Type: application/json"; "Prefer: return=representation,resolution=merge-duplicates")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPostFields"; $curl; $json)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $curl)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$perform</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $curl)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $curl)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $curl)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Msgbox"; "Archivy Sync Kontakte Push" & Char(182) & "HTTP: " & $http & Char(182) & "Gesendet: " & $anzahl & Char(182) & "BVH im Payload: ja (Feld 'bvh')" & Char(182) & Char(182) & "Antwort (Anfang): " & Left ( $resp ; 500 ))]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$msg</Name>
</Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="89" name="# (comment)"><Text>Hinweis: Falls Feldnamen abweichen, im SELECT die FM-Spaltennamen anpassen. Wichtig ist, dass BVH auf den JSON-Key 'bvh' gemappt bleibt.</Text></Step>
</fmxmlsnippet>
