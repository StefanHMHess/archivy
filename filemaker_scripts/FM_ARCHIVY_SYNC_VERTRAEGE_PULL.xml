<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC VERTRAEGE PULL - holt Vertraege aus Supabase fuer den persoenlichen Inhaber nach FileMaker.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[GetAsTimestamp ( $$LAST_PULL_VERTRAEGE )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seitTS</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[IsEmpty ( $seitTS )]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["1970-01-01T00:00:00Z"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seit</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[GetAsText ( $seitTS )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seit</Name>
</Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Text.EncodeToURL"; $seit; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seitURL</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
$$SUPABASE_URL & "/rest/v1/vertraege?vertragsbesitzer_id=eq." & $$INHABER_ID &
"&app_modified_at=gt." & $seitURL &
"&order=app_modified_at.asc" &
"&select=vertrag_id,gruppe,untergruppe,firma,beschreibung,vertragsnummer,kosten_jaehrlich,aktiv,app_modified_at" &
"&limit=" & $$SYNC_LIMIT
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c; $url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c; "apikey: " & $key; "Authorization: Bearer " & $key)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $resp ; 1 ) = "[" ; ValueCount ( JSONListKeys ( $resp ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$seit]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$maxTs</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$ok + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$i > $anzahl]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$idx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[JSONGetElement ( $resp ; "[" & $idx & "].vertrag_id" )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$vertrag_id</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].gruppe" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$gruppe</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].untergruppe" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$untergruppe</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].firma" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$firma</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].beschreibung" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$beschreibung</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].vertragsnummer" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$vertragsnummer</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].kosten_jaehrlich" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$kosten</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].aktiv" ) ; If ( w = "null" ; 1 ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$aktiv</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].app_modified_at" ) ; If ( w = "null" ; $maxTs ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$rowTs</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.ExecuteFileSQL"; Get(FileName);
"UPDATE \"Vertraege\" SET \"gruppe\"=?, \"untergruppe\"=?, \"firma\"=?, \"beschreibung\"=?, \"vertragsnummer\"=?, \"kosten_jaehrlich\"=?, \"aktiv\"=?, \"sync_state\"=? WHERE \"vertrag_id\"=?";
9; 13; $gruppe; $untergruppe; $firma; $beschreibung; $vertragsnummer; $kosten; $aktiv; "synchronisiert"; $vertrag_id)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$upd</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & If ( Left ( $upd ; 5 ) = "[MBS]" ; "Vertrag " & $vertrag_id & ": " & $upd & ¶ ; "" )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[Left ( $upd ; 5 ) = "[MBS]"]]></Calculation>
</Step>
<Step enable="True" id="89" name="# (comment)"><Text>Falls Update nichts trifft, Datensatz neu anlegen:</Text></Step>
<Step enable="True" id="3" name="New Record/Request"></Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="vertrag_id" name="vertrag_id"/>
<Calculation><![CDATA[$vertrag_id]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="gruppe" name="gruppe"/>
<Calculation><![CDATA[$gruppe]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="untergruppe" name="untergruppe"/>
<Calculation><![CDATA[$untergruppe]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="firma" name="firma"/>
<Calculation><![CDATA[$firma]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="beschreibung" name="beschreibung"/>
<Calculation><![CDATA[$beschreibung]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="vertragsnummer" name="vertragsnummer"/>
<Calculation><![CDATA[$vertragsnummer]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="kosten_jaehrlich" name="kosten_jaehrlich"/>
<Calculation><![CDATA[$kosten]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="aktiv" name="aktiv"/>
<Calculation><![CDATA[$aktiv]]></Calculation>
</Step>
<Step enable="True" id="118" name="Set Field">
<Field table="Vertraege" id="sync_state" name="sync_state"/>
<Calculation><![CDATA["synchronisiert"]]></Calculation>
</Step>
<Step enable="True" id="75" name="Commit Records/Requests"/>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( $rowTs &gt; $maxTs ; $rowTs ; $maxTs )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$maxTs</Name>
</Step>
<Step enable="True" id="73" name="End Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$maxTs]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$$LAST_PULL_VERTRAEGE</Name>
</Step>
<Step enable="True" id="133" name="Show Custom Dialog">
<Title><Calculation><![CDATA["Archivy Sync: Vertraege Pull"]]></Calculation></Title>
<Message><Calculation><![CDATA["Datensaetze gelesen: " & $anzahl & ¶ & "Fehler: " & If ( IsEmpty ( $fehler ) ; "keine" ; Left ( $fehler ; 1000 ) )]]></Calculation></Message>
<Buttons>
<Button CommitState="Yes" ID="1"><Label>OK</Label></Button>
</Buttons>
</Step>
</fmxmlsnippet>
