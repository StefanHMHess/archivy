<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC VORGAENGE PDF PUSH (Container) - Leitfaden-konform mit FM.SQL.Field fuer echte Container-Base64daten.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Case ( not IsEmpty ( $$SUPABASE_SERVICE_KEY ) ; $$SUPABASE_SERVICE_KEY ; $$SUPABASE_KEY )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$base_url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Lower ( $$INHABER_ID )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$owner_id</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$base_url & "/storage/v1/object/archivy-dokumente/"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$storage_url_base</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$base_url & "/rest/v1/vorgaenge?on_conflict=vorgang_id"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$upsert_url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$skip</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$auth_blocked</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[IsEmpty ( $key ) or IsEmpty ( $base_url ) or IsEmpty ( $owner_id ) or IsEmpty ( $$FM_VORGAENGE_TABELLE ) or IsEmpty ( $$FM_VERTRAEGE_TABELLE )]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Msgbox"; "Archivy Sync abgebrochen" & Char(182) & "Bitte zuerst FM_ARCHIVY_SYNC_INIT ausfuehren und $$FM_VORGAENGE_TABELLE / $$FM_VERTRAEGE_TABELLE setzen.")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$msg</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Let([
ts = GetAsTimestamp ( Get ( CurrentHostTimestamp ) ) ;
d = GetAsDate ( ts ) ;
t = GetAsTime ( ts )
] ;
Year ( d ) & "-" & Right ( "0" & Month ( d ) ; 2 ) & "-" & Right ( "0" & Day ( d ) ; 2 ) & "T" &
Right ( "0" & Hour ( t ) ; 2 ) & ":" & Right ( "0" & Minute ( t ) ; 2 ) & ":" & Right ( "0" & Int ( Seconds ( t ) ) ; 2 ) & "Z"
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ts_iso</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.SQL.Execute"; "";
"SELECT \"Vertrag_ID\" FROM \"" & $$FM_VERTRAEGE_TABELLE & "\" WHERE \"Archivy_sync\" IN ('x','X')")
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$sql_marked</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
If ( Left ( $sql_marked ; 5 ) = "[MBS]" ; "[]" ; MBS("FM.SQL.JSONRecords"; $sql_marked; "vertrag_id") )
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$json_marked</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $json_marked ; 1 ) = "[" and PatternCount ( $json_marked ; "Syntax error" ) = 0 and PatternCount ( $json_marked ; "Line 1, Column" ) = 0 ; ValueCount ( JSONListKeys ( $json_marked ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$marked_count</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$marked_list</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$m</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$m + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$m</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$m > $marked_count]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$m - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$midx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Lower ( TrimAll ( GetAsText ( JSONGetElement ( $json_marked ; "[" & $midx & "].vertrag_id" ) ) ; 1 ; 1 ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$mk</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Case ( IsEmpty ( $mk ) ; $marked_list ; List ( $marked_list ; $mk ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$marked_list</Name>
</Step>
<Step enable="True" id="73" name="End Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $sql_marked ; 5 ) = "[MBS]" ; "" ; MBS("FM.SQL.Release"; $sql_marked) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$rel_marked</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$marked_count = 0]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & "Keine markierten Vertraege mit Archivy_sync = x gefunden." & Char(182)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.SQL.Execute"; "";
"SELECT \"Vorgang_ID\", \"Vertrag\", \"Art der Erledigung\", \"Datum\", \"Frist\", \"Datei\" FROM \"" & $$FM_VORGAENGE_TABELLE & "\" WHERE \"Datei\" IS NOT NULL")
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$sql</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $sql ; 5 ) = "[MBS]" ; $fehler & "SQL Fehler bei Datenselektion: " & Left ( $sql ; 220 ) & Char(182) ; $fehler )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $sql ; 5 ) = "[MBS]" ; 0 ; GetAsNumber ( MBS("FM.SQL.RowCount"; $sql) ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$i > $anzahl]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$idx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[TrimAll ( GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 0 ) ) ; 1 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$vorgang_id</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[TrimAll ( GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 1 ) ) ; 1 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$vertrag_raw</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Lower ( $vertrag_raw )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$vertrag_key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[PatternCount ( "¶" & $marked_list & "¶" ; "¶" & $vertrag_key & "¶" ) > 0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$is_marked</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[TrimAll ( GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 2 ) ) ; 1 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$art</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[not $is_marked]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$skip + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$skip</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[TrimAll ( GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 3 ) ) ; 1 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$datum_raw</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[TrimAll ( GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 4 ) ) ; 1 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$frist_raw</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[GetAsText ( MBS("FM.SQL.Field"; $sql; $idx; 5; 2 ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$datei_payload</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[IsEmpty ( $vorgang_id ) or IsEmpty ( $datei_payload )]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$skip + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$skip</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[Left ( $datei_payload ; 5 ) <> "JVBER"]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$skip + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$skip</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & "Vorgang " & $vorgang_id & ": Container liefert kein PDF-Base64 (Prefix=" & Left ( $datei_payload ; 12 ) & ")." & Char(182)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Substitute ( "vorgang_" & $vorgang_id & ".pdf" ;
[ " " ; "_" ] ;
[ "/" ; "_" ] ;
[ "\\" ; "_" ] ;
[ ":" ; "_" ] ;
[ "*" ; "_" ] ;
[ "?" ; "_" ] ;
[ "<" ; "_" ] ;
[ ">" ; "_" ] ;
[ "|" ; "_" ]
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$datei_name</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["owners/" & $owner_id & "/vorgaenge/" & $vorgang_id & "/" & $datei_name]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$storage_path</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Container.DecodeFromBase64"; "PDF"; $datei_payload; $datei_name; 1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$pdf_container</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c; $storage_url_base & $storage_path)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionUpload"; $c; 1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionCustomRequest"; $c; "POST")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c; "apikey: " & $key; "Authorization: Bearer " & $key; "x-upsert: true"; "Content-Type: application/pdf")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetInputFile"; $c; $pdf_container)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$http = 200 or $http = 201 or $http = 204]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Let([ d = GetValue(Substitute($datum_raw; " "; ""); 1) ];
Case(
IsEmpty(d); "";
PatternCount(d; "-") = 2; Left(d; 10);
PatternCount(d; ".") = 2; Let([
 p1=Position(d;".";1;1); p2=Position(d;".";1;2);
 day=Left(d;p1-1); mon=Middle(d;p1+1;p2-p1-1);
 yr0=GetValue(Substitute(Middle(d;p2+1;99);" ";"");1);
 yr=Case(Length(yr0)=2;"20"&yr0;yr0)
]; yr&"-"&Right("0"&mon;2)&"-"&Right("0"&day;2));
PatternCount(d; "/") = 2; Let([
 p1=Position(d;"/";1;1); p2=Position(d;"/";1;2);
 mon=Left(d;p1-1); day=Middle(d;p1+1;p2-p1-1);
 yr0=GetValue(Substitute(Middle(d;p2+1;99);" ";"");1);
 yr=Case(Length(yr0)=2;"20"&yr0;yr0)
]; yr&"-"&Right("0"&mon;2)&"-"&Right("0"&day;2));
""
))
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$datum_iso</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Let([ d = GetValue(Substitute($frist_raw; " "; ""); 1) ];
Case(
IsEmpty(d); "";
PatternCount(d; "-") = 2; Left(d; 10);
PatternCount(d; ".") = 2; Let([
 p1=Position(d;".";1;1); p2=Position(d;".";1;2);
 day=Left(d;p1-1); mon=Middle(d;p1+1;p2-p1-1);
 yr0=GetValue(Substitute(Middle(d;p2+1;99);" ";"");1);
 yr=Case(Length(yr0)=2;"20"&yr0;yr0)
]; yr&"-"&Right("0"&mon;2)&"-"&Right("0"&day;2));
PatternCount(d; "/") = 2; Let([
 p1=Position(d;"/";1;1); p2=Position(d;"/";1;2);
 mon=Left(d;p1-1); day=Middle(d;p1+1;p2-p1-1);
 yr0=GetValue(Substitute(Middle(d;p2+1;99);" ";"");1);
 yr=Case(Length(yr0)=2;"20"&yr0;yr0)
]; yr&"-"&Right("0"&mon;2)&"-"&Right("0"&day;2));
""
))
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$frist_iso</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
JSONSetElement ( "{}" ;
[ "vorgang_id" ; $vorgang_id ; JSONString ] ;
[ "vertragsbesitzer_id" ; $owner_id ; JSONString ] ;
[ "vertrag" ; $vertrag_raw ; JSONString ] ;
[ "vorgang_art" ; $art ; JSONString ] ;
[ "kurzbeschreibung" ; $art ; JSONString ] ;
[ "datum" ; $datum_iso ; If ( IsEmpty ( $datum_iso ) ; JSONNull ; JSONString ) ] ;
[ "frist" ; $frist_iso ; If ( IsEmpty ( $frist_iso ) ; JSONNull ; JSONString ) ] ;
[ "datei_pfad" ; $storage_path ; JSONString ] ;
[ "sync_state" ; "geaendert" ; JSONString ]
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$obj</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["[" & $obj & "]"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$body</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$base_url & "/rest/v1/vorgaenge?select=vorgang_id&vorgang_id=eq." & $vorgang_id & "&vertragsbesitzer_id=eq." & $owner_id]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$check_url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c0</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c0; $check_url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c0; "apikey: " & $key; "Authorization: Bearer " & $key; "Accept: application/json")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c0)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c0)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http0</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c0; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp0</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c0)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$http0 <> 200]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & "Vorgang " & $vorgang_id & " CHECK HTTP " & $http0 & ": " & Left ( $resp0 ; 180 ) & Char(182)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$skip]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$skip</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
