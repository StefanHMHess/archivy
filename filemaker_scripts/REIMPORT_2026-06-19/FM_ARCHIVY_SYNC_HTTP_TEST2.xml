<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>HTTP TEST v2 - kein Dialog. Ergebnis in $$DIAGNOSE sichtbar im Datenbetrachter.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$base_url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c1</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c1; $base_url & "/rest/v1/vertraege?select=vertrag_id&limit=3")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c1; "apikey: " & $key; "Authorization: Bearer " & $key; "Accept: application/json")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http_get</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c1; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp_get</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["URL=" & If(IsEmpty($base_url);"LEER";"JA") & " KEY=" & If(IsEmpty($key);"LEER";Length($key) & "chr") & " HTTP=" & $http_get & " RESP=" & Left($resp_get;500)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$$DIAGNOSE</Name>
</Step>
</fmxmlsnippet>
