<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>HTTP TEST - macht einen einzigen GET und einen POST zu Supabase und zeigt Ergebnis an. Dient zur Diagnose von Credentials und RLS.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$base_url</Name>
</Step>
<Step enable="True" id="89" name="# (comment)"><Text>=== SCHRITT 1: GET - lese Vertraege (leer ist ok, 401 = Auth-Problem) ===</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c1</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c1; $base_url & "/rest/v1/vertraege?select=vertrag_id&limit=3")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c1; "apikey: " & $key; "Authorization: Bearer " & $key; "Accept: application/json")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http_get</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c1; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp_get</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="89" name="# (comment)"><Text>=== SCHRITT 2: POST Upsert - schreibt einen Testdatensatz ===</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
JSONSetElement ( "{}" ;
[ "vertrag_id" ; "FM-TEST-001" ; JSONString ] ;
[ "vertragsbesitzer_id" ; Lower ( $$INHABER_ID ) ; JSONString ] ;
[ "gruppe" ; "Test" ; JSONString ] ;
[ "firma" ; "HTTP-Diagnose" ; JSONString ] ;
[ "sync_state" ; "geaendert" ; JSONString ] ;
[ "app_modified_at" ; Get ( CurrentHostTimestamp ) ; JSONString ]
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$test_body</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["[" & $test_body & "]"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$test_body</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c2</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c2; $base_url & "/rest/v1/vertraege?on_conflict=vertrag_id")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPost"; $c2; 1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c2; "apikey: " & $key; "Authorization: Bearer " & $key; "Content-Type: application/json"; "Prefer: resolution=merge-duplicates,return=minimal")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPostFields"; $c2; $test_body)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c2)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c2)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http_post</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c2; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp_post</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c2)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="133" name="Show Custom Dialog">
<Title><Calculation><![CDATA["Archivy HTTP Diagnose"]]></Calculation></Title>
<Message><Calculation><![CDATA[
"CREDENTIALS:" & ¶ &
"  URL: " & If ( IsEmpty ( $base_url ) ; "LEER!" ; Left ( $base_url ; 50 ) ) & ¶ &
"  KEY: " & If ( IsEmpty ( $key ) ; "LEER!" ; "vorhanden (" & Length ( $key ) & " Zeichen)" ) & ¶ &
"  INHABER: " & Lower ( $$INHABER_ID ) & ¶ & ¶ &
"GET /vertraege (Lesen):" & ¶ &
"  HTTP " & $http_get & If ( $http_get = 200 ; " - OK" ; If ( $http_get = 401 ; " - NICHT AUTORISIERT" ; If ( $http_get = 0 ; " - KEINE VERBINDUNG" ; " - FEHLER" ) ) ) & ¶ &
"  Antwort: " & Left ( $resp_get ; 200 ) & ¶ & ¶ &
"POST /vertraege (Schreiben FM-TEST-001):" & ¶ &
"  HTTP " & $http_post & If ( $http_post = 200 or $http_post = 201 or $http_post = 204 ; " - OK (geschrieben)" ; If ( $http_post = 401 ; " - NICHT AUTORISIERT" ; If ( $http_post = 403 ; " - VERBOTEN (RLS)" ; If ( $http_post = 0 ; " - KEINE VERBINDUNG" ; " - FEHLER" ) ) ) ) & ¶ &
"  Antwort: " & Left ( $resp_post ; 300 )
]]></Calculation></Message>
<Buttons>
<Button CommitState="Yes" ID="1"><Label>OK</Label></Button>
</Buttons>
</Step>
</fmxmlsnippet>
