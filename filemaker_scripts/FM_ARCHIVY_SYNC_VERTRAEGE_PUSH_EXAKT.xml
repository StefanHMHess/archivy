<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC VERTRAEGE PUSH (exakt) - uebertraegt nur Datensaetze mit Archivy_sync = x und leert die Markierung nach Erfolg.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
Let([
	ts = GetAsTimestamp ( Get ( CurrentHostTimestamp ) ) ;
	d = GetAsDate ( ts ) ;
	t = GetAsTime ( ts )
] ;
	Year ( d ) & "-" & Right ( "0" & Month ( d ) ; 2 ) & "-" & Right ( "0" & Day ( d ) ; 2 ) & "T" &
	Right ( "0" & Hour ( t ) ; 2 ) & ":" & Right ( "0" & Minute ( t ) ; 2 ) & ":" & Right ( "0" & Int ( Seconds ( t ) ) ; 2 ) & "Z"
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ts_iso</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL & "/rest/v1/vertraege?on_conflict=vertrag_id"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.SQL.Execute"; "";
"SELECT \"Vertrag_ID\", \"Vertragseigentümer\", \"Gruppe\", \"Untergruppe\", \"Firma\", \"Beschreibung\", \"Vertragsnummer\", \"Kontakt\", \"Telefon\", \"Mobil\", \"Fax\", \"Email\", \"Webseite\", \"Zugang\", \"Passwort\", \"IBAN\", \"BIC\", \"Bank\", \"Jahresraten\", \"Kosten pro Rate\", \"Kosten jährlich\", \"Zahlungsweise\", \"Vertrag\", \"Vertrags_Datum\", \"Vertrags_Beginn\", \"Vertrags_Ablauf\", \"Logo\" FROM \"" & $$FM_VERTRAEGE_TABELLE & "\" WHERE \"Archivy_sync\" = 'x'")
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$sql</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
MBS("FM.SQL.JSONRecords"; $sql;
"vertrag_id" & ¶ &
"vertragseigentuemer" & ¶ &
"gruppe" & ¶ &
"untergruppe" & ¶ &
"firma" & ¶ &
"beschreibung" & ¶ &
"vertragsnummer" & ¶ &
"kontakt" & ¶ &
"telefon" & ¶ &
"mobil" & ¶ &
"fax" & ¶ &
"email" & ¶ &
"webseite" & ¶ &
"zugang" & ¶ &
"passwort" & ¶ &
"iban" & ¶ &
"bic" & ¶ &
"bank" & ¶ &
"jahresraten" & ¶ &
"kosten_pro_rate" & ¶ &
"kosten_jaehrlich" & ¶ &
"zahlungsweise" & ¶ &
"vertrag" & ¶ &
"vertrags_datum" & ¶ &
"vertrags_beginn" & ¶ &
"vertrags_ablauf" & ¶ &
"logo")
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$json</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $json ; 1 ) = "[" and PatternCount ( $json ; "Syntax error" ) = 0 and PatternCount ( $json ; "Line 1, Column" ) = 0 ; ValueCount ( JSONListKeys ( $json ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $json ; 1 ) = "[" and PatternCount ( $json ; "Syntax error" ) = 0 and PatternCount ( $json ; "Line 1, Column" ) = 0 ; "" ; Left ( "JSON_PARSE_ERROR: " & $json ; 200 ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$i > $anzahl]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$idx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[
JSONSetElement ( "{}" ;
[ "vertrag_id" ; JSONGetElement ( $json ; "[" & $idx & "].vertrag_id" ) ; JSONString ] ;
[ "vertragsbesitzer_id" ; Lower ( $$INHABER_ID ) ; JSONString ] ;
[ "gruppe" ; JSONGetElement ( $json ; "[" & $idx & "].gruppe" ) ; JSONString ] ;
[ "untergruppe" ; JSONGetElement ( $json ; "[" & $idx & "].untergruppe" ) ; JSONString ] ;
[ "firma" ; JSONGetElement ( $json ; "[" & $idx & "].firma" ) ; JSONString ] ;
[ "kontakt" ; JSONGetElement ( $json ; "[" & $idx & "].kontakt" ) ; JSONString ] ;
[ "beschreibung" ; JSONGetElement ( $json ; "[" & $idx & "].beschreibung" ) ; JSONString ] ;
[ "vertragsnummer" ; JSONGetElement ( $json ; "[" & $idx & "].vertragsnummer" ) ; JSONString ] ;
[ "datei_pfad_2" ; JSONGetElement ( $json ; "[" & $idx & "].logo" ) ; JSONString ] ;
[ "notizen" ; JSONGetElement ( $json ; "[" & $idx & "].vertrag" ) ; JSONString ] ;
[ "sync_state" ; "geaendert" ; JSONString ] ;
[ "app_modified_at" ; If ( IsEmpty ( $ts_iso ) ; "1970-01-01T00:00:00Z" ; $ts_iso ) ; JSONString ]
)
]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$obj</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["[" & $obj & "]"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$body</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c; $url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPost"; $c; 1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c; "apikey: " & $key; "Authorization: Bearer " & $key; "Content-Type: application/json"; "Prefer: resolution=merge-duplicates,return=minimal")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPostFields"; $c; $body)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$http = 200 or $http = 201 or $http = 204]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.ExecuteFileSQL"; Get(FileName); "UPDATE \"" & $$FM_VERTRAEGE_TABELLE & "\" SET \"Archivy_sync\" = '' WHERE \"Vertrag_ID\" = ?"; 9; 13; JSONGetElement ( $json ; "[" & $idx & "].vertrag_id" ))]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$clr</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$ok + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & "Vertrag_ID " & JSONGetElement ( $json ; "[" & $idx & "].vertrag_id" ) & ": HTTP " & $http & " - " & Left ( $resp ; 200 ) & ¶]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="73" name="End Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.SQL.Release"; $sql)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$rel</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["VERTRAEGE: verarbeitet=" & $anzahl & " ok=" & $ok & " fehler=" & If(IsEmpty($fehler);"keine";Left($fehler;500))]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$$SYNC_RESULT_V</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Msgbox"; $$SYNC_RESULT_V)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$msg</Name>
</Step>
</fmxmlsnippet>



