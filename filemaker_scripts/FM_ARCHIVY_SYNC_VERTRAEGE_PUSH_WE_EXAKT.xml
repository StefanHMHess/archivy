<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC VERTRAEGE PUSH (WE exakt) - nutzt exakte Feldnamen aus deiner FM-XML.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL & "/rest/v1/vertraege?on_conflict=vertrag_id"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.SQL.Execute"; ""; "SELECT \"WE_ID\", \"BVH\", \"BA\", \"Beschreibung\", \"Art\", \"Status\", \"Preisliste\", \"WF\", \"Zimmerzahl\", \"BezFert_Jahr\", \"Straße\", \"Ort\", \"Summe_Vertragssumme\", \"IP\", \"IM_Bezeichnung\" FROM \"WE\" WHERE \"IM_sync\" = 'x'")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$sql</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.SQL.JSONRecords"; $sql; "we_id" & ¶ & "bvh" & ¶ & "ba" & ¶ & "beschreibung" & ¶ & "art" & ¶ & "status" & ¶ & "preisliste" & ¶ & "wf" & ¶ & "zimmerzahl" & ¶ & "bezfert_jahr" & ¶ & "strasse" & ¶ & "ort" & ¶ & "summe_vertragssumme" & ¶ & "ip" & ¶ & "im_bezeichnung")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$json</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $json ; 1 ) = "[" ; ValueCount ( JSONListKeys ( $json ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$i > $anzahl]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$idx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[JSONGetElement ( $json ; "[" & $idx & "].we_id" )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$weid</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Case ( IsEmpty ( $weid ) ; "" ; JSONSetElement ( "{}" ; [ "vertrag_id" ; $weid ; JSONString ] ; [ "vertragsbesitzer_id" ; $$INHABER_ID ; JSONString ] ; [ "gruppe" ; JSONGetElement ( $json ; "[" & $idx & "].art" ) ; JSONString ] ; [ "untergruppe" ; JSONGetElement ( $json ; "[" & $idx & "].ba" ) ; JSONString ] ; [ "firma" ; JSONGetElement ( $json ; "[" & $idx & "].im_bezeichnung" ) ; JSONString ] ; [ "beschreibung" ; JSONGetElement ( $json ; "[" & $idx & "].beschreibung" ) ; JSONString ] ; [ "vertragsnummer" ; JSONGetElement ( $json ; "[" & $idx & "].bvh" ) ; JSONString ] ; [ "kosten_jaehrlich" ; JSONGetElement ( $json ; "[" & $idx & "].summe_vertragssumme" ) ; JSONNumber ] ; [ "aktiv" ; Case ( Lower ( JSONGetElement ( $json ; "[" & $idx & "].status" ) ) = "verkauft" or Lower ( JSONGetElement ( $json ; "[" & $idx & "].status" ) ) = "vermietet" ; False ; True ) ; JSONBoolean ] ; [ "notizen" ; JSONGetElement ( $json ; "[" & $idx & "].beschreibung" ) ; JSONString ] ; [ "sync_state" ; "geaendert" ; JSONString ] ; [ "app_modified_at" ; Get ( CurrentHostTimestamp ) ; JSONString ] ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$obj</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[not IsEmpty ( $obj )]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA["[" & $obj & "]"]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$body</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c; $url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPost"; $c; 1)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c; "apikey: " & $key; "Authorization: Bearer " & $key; "Content-Type: application/json"; "Prefer: resolution=merge-duplicates,return=minimal")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionPostFields"; $c; $body)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="68" name="If">
<Calculation><![CDATA[$http = 200 or $http = 201 or $http = 204]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$ok + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="69" name="Else"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & "WE_ID " & $weid & " HTTP " & $http & ": " & Left ( $resp ; 200 ) & ¶]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="70" name="End If"></Step>
<Step enable="True" id="73" name="End Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.SQL.Release"; $sql)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$rel</Name>
</Step>
<Step enable="True" id="133" name="Show Custom Dialog">
<Title><Calculation><![CDATA["Archivy Sync Push (WE exakt)"]]></Calculation></Title>
<Message><Calculation><![CDATA["Verarbeitet: " & $anzahl & ¶ & "Erfolgreich: " & $ok & ¶ & If ( IsEmpty ( $fehler ) ; "Fehler: keine" ; "Fehler:" & ¶ & Left ( $fehler ; 1000 ) )]]></Calculation></Message>
<Buttons>
<Button CommitState="Yes" ID="1"><Label>OK</Label></Button>
</Buttons>
</Step>
</fmxmlsnippet>
