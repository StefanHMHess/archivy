<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)"><Text>ARCHIVY SYNC VERTRAEGE PULL (WE exakt) - schreibt Supabase-Vertraege in exakte WE-Felder.</Text></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_KEY]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$key</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Case ( IsEmpty ( $$LAST_PULL_VERTRAEGE ) ; "1970-01-01T00:00:00Z" ; $$LAST_PULL_VERTRAEGE )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seit</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("Text.EncodeToURL"; $seit; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$seitURL</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$$SUPABASE_URL & "/rest/v1/vertraege?vertragsbesitzer_id=eq." & $$INHABER_ID & "&app_modified_at=gt." & $seitURL & "&order=app_modified_at.asc&select=vertrag_id,gruppe,untergruppe,firma,beschreibung,vertragsnummer,kosten_jaehrlich,aktiv,app_modified_at&limit=" & $$SYNC_LIMIT]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$url</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.New")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$c</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionURL"; $c; $url)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.SetOptionHTTPHeader"; $c; "apikey: " & $key; "Authorization: Bearer " & $key)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Perform"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResultAsText"; $c; "UTF-8")]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$resp</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.GetResponseCode"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$http</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("CURL.Cleanup"; $c)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$r</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( Left ( $resp ; 1 ) = "[" ; ValueCount ( JSONListKeys ( $resp ; "" ) ) ; 0 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$anzahl</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[0]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[""]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$seit]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$maxTs</Name>
</Step>
<Step enable="True" id="71" name="Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$i</Name>
</Step>
<Step enable="True" id="72" name="Exit Loop If">
<Calculation><![CDATA[$i > $anzahl]]></Calculation>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$i - 1]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$idx</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[JSONGetElement ( $resp ; "[" & $idx & "].vertrag_id" )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$weid</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].gruppe" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$art</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].untergruppe" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ba</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].firma" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$bezeichnung</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].beschreibung" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$beschreibung</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].kosten_jaehrlich" ) ; If ( w = "null" ; "" ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$summe</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[MBS("FM.ExecuteFileSQL"; Get(FileName); "UPDATE \"WE\" SET \"Art\"=?, \"BA\"=?, \"IM_Bezeichnung\"=?, \"Beschreibung\"=?, \"Summe_Vertragssumme\"=?, \"IM_sync_status\"='synchronisiert' WHERE \"WE_ID\"=?"; 9; 13; $art; $ba; $bezeichnung; $beschreibung; $summe; $weid)]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$upd</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$ok + If ( Left ( $upd ; 5 ) = "[MBS]" ; 0 ; 1 )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$ok</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$fehler & If ( Left ( $upd ; 5 ) = "[MBS]" ; "WE_ID " & $weid & ": " & $upd & ¶ ; "" )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$fehler</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[Let ( w = JSONGetElement ( $resp ; "[" & $idx & "].app_modified_at" ) ; If ( w = "null" ; $maxTs ; w ) )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$rowTs</Name>
</Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[If ( $rowTs &gt; $maxTs ; $rowTs ; $maxTs )]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$maxTs</Name>
</Step>
<Step enable="True" id="73" name="End Loop"></Step>
<Step enable="True" id="141" name="Set Variable">
<Value><Calculation><![CDATA[$maxTs]]></Calculation></Value>
<Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
<Name>$$LAST_PULL_VERTRAEGE</Name>
</Step>
<Step enable="True" id="133" name="Show Custom Dialog">
<Title><Calculation><![CDATA["Archivy Sync Pull (WE exakt)"]]></Calculation></Title>
<Message><Calculation><![CDATA["Gelesen: " & $anzahl & ¶ & "Aktualisiert: " & $ok & ¶ & If ( IsEmpty ( $fehler ) ; "Fehler: keine" ; "Fehler:" & ¶ & Left ( $fehler ; 1000 ) )]]></Calculation></Message>
<Buttons>
<Button CommitState="Yes" ID="1"><Label>OK</Label></Button>
</Buttons>
</Step>
</fmxmlsnippet>
